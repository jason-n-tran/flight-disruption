# MLflow — defaults to a local file store at ./mlruns if unset. No server needed.
# (MLflow 3.x rejects the file store unless MLFLOW_ALLOW_FILE_STORE=true, which
#  the pipeline sets automatically for the local-demo default.)
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_ALLOW_FILE_STORE=true
MLFLOW_EXPERIMENT=flight_delay
MLFLOW_MODEL_NAME=flight_delay_lgbm

# Lakehouse root (where gold/fct_flight_features lives). Used in non-synthetic runs.
LAKE_ROOT=../data/lake

# Force UTF-8 stdout so report prints (with the "▲" arrows etc.) don't crash on Windows.
PYTHONIOENCODING=utf-8
