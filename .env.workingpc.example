# Working PC (.env) — heavy batch + ML. Builds the lake and publishes artifacts.

LAKE_ROOT=./data/lake
DUCKDB_PATH=./data/lake/gold.duckdb
BTS_YEARS=2022,2023,2024,2025      # model training span
BRONZE_YEARS=2015,2016,2017,2018,2019,2022,2023,2024,2025  # dashboards (skip COVID)
# Weather is scoped to airports present in BTS, ranked by flight volume.
# Open-Meteo free tier = 10,000 weighted calls/day; a 4yr x 5var pull is
# ~104 units/airport, so only ~90 airports fit per day. Weather ingest stops at
# INGEST_WEATHER_DAILY_BUDGET (default 90) and RESUMES on the next run, so a
# WEATHER_TOP_N=200 backfill completes over ~3 daily runs.
# To finish in ONE run, set WEATHER_TOP_N=90 (covers most US flights; tail
# airports get neutral fill-default weather).
WEATHER_TOP_N=200
# INGEST_WEATHER_DAILY_BUDGET=90      # airports/day cap (free-tier quota guard)

# Publish target so the VPS serving API can pull `latest`
S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
S3_BUCKET=flight-artifacts
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
