# VPS (.env) — only the FastAPI serving API runs here. Frontend = Cloudflare Pages.
# Point at TrueNAS (Tailscale IPs) for live cache + object storage for artifacts.

VALKEY_HOST=100.x.y.z            # TrueNAS Tailscale IP
VALKEY_PORT=6379
NATS_URL=nats://100.x.y.z:4223   # optional (serving doesn't strictly need it)

# Artifact pull (Working PC publishes here; API pulls `latest` on startup)
S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com   # or MinIO on TrueNAS
S3_BUCKET=flight-artifacts
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
DATA_VERSION=latest

# The deployed Cloudflare Pages origin (CORS)
ALLOWED_ORIGINS=https://flight-disruption.pages.dev
