# ---------------------------------------------------------------------------
# Environment for the dbt-duckdb gold-marts project.
# Copy to .env and `source` it (or use direnv) before running dbt. Never commit .env.
# ---------------------------------------------------------------------------

# Root of the PySpark lakehouse output. dbt sources read silver parquet from
# here (e.g. $LAKE_ROOT/silver/flights/**/*.parquet) when use_seeds=false.
LAKE_ROOT=./data/lake

# DuckDB file the marts are written to AND the serving API reads from.
# Keep this in sync with the serving layer's DUCKDB_PATH.
DUCKDB_PATH=./data/lake/gold.duckdb

# Tell dbt where to find profiles.yml (this project ships its own, in dbt/flight/).
DBT_PROFILES_DIR=./dbt/flight
