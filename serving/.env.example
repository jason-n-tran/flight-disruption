# --- Serving API config (copy to .env; never commit .env) ---

# Gold marts (DuckDB, opened read-only). Local dev -> bundled sample.
DUCKDB_PATH=../data/sample/gold.duckdb

# Model bundle: MODEL_PATH points at model.lgb; the bundle dir is its parent
# (must also contain calibrator.pkl + feature_metadata.json).
MODEL_PATH=../data/sample/model.lgb

# Bundled sample fallback dir (artifacts + positions.json).
SAMPLE_DIR=../data/sample

# Version string surfaced in /health and prediction responses.
DATA_VERSION=sample

# --- Live positions cache (Valkey / redis protocol) ---
# Leave VALKEY_HOST blank to disable Valkey and always serve sample positions.
VALKEY_HOST=localhost
VALKEY_PORT=6379
# Positions newer than this (seconds) are labelled "live", older -> "cached".
LIVE_FRESH_SECONDS=120

# --- CORS (comma-separated allowed origins for the frontend) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Weather forecast (graceful-degrade to defaults if unreachable) ---
WEATHER_ENABLED=true
WEATHER_TIMEOUT_SECONDS=4

# --- Optional: pull latest artifacts from object storage on startup ---
# Set ALL of S3_ENDPOINT/S3_BUCKET/S3_ACCESS_KEY_ID to enable; else sample is used.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=artifacts/latest
S3_REGION=us-east-1
ARTIFACT_CACHE_DIR=/artifacts
