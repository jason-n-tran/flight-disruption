# TrueNAS (.env) — always-on live path: NATS + live-stream consumer.
# (This overlay REUSES your existing TrueNAS Valkey — it does NOT start one.)

# OpenSky (free account MANDATORY for sustained polling — anon=400/day,
# standard=4000/day; US bbox costs 4 credits/call). Create at:
#   https://opensky-network.org/  (OAuth2 client credentials)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
POLL_INTERVAL_SECONDS=60          # viewer-gated; backs off to idle when no viewers

# --- Reaching your existing TrueNAS Valkey (NOT the literal `valkey`) ---
# The live-stream container is in Flight's own compose network, so a bare
# service name from another project will NOT resolve. Use ONE of:
#   A) The TrueNAS host IP (or its Tailscale IP) + the published Valkey port:
#        VALKEY_HOST=100.x.y.z         (or the LAN IP of TrueNAS)
#        VALKEY_PORT=6379
#   B) If your Valkey runs in Docker, attach Flight to that Docker network and
#      use the Valkey container name (see deployment.md §4 for the external-
#      network snippet), then VALKEY_HOST=<valkey_container_name>.
# Do NOT use VALKEY_HOST=valkey unless you run Flight's OWN bundled valkey.
VALKEY_HOST=
VALKEY_PORT=6379