# Flight Disruption Platform — local dev env. Copy to .env; defaults work as-is.
# `docker compose up` runs fully on bundled sample artifacts with everything below blank.

# ---- Serving API ----
DATA_VERSION=sample
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
PUBLIC_API_BASE=http://localhost:8005

# ---- Live cache (Valkey). Local default = the compose `valkey` service. ----
# Production: set to the shared TrueNAS Valkey Tailscale IP. Keyspace prefix is
# `flight:` (enforced in code) so it can share an instance with other projects.
VALKEY_HOST=valkey
VALKEY_PORT=6379

# ---- Event bus (NATS). Local default = the compose `nats` service. ----
NATS_URL=nats://nats:4223

# ---- OpenSky (live map). Free account MANDATORY for live polling. ----
# Without these, the live-stream service is skipped and the map serves sample
# positions. Create at https://opensky-network.org/ (OAuth2 client credentials).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
POLL_INTERVAL_SECONDS=60

# ---- Object storage (artifact handoff). Blank = use bundled sample artifacts. ----
# Production: MinIO on TrueNAS or Backblaze B2. API pulls `latest` on startup.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- Local pipeline (Working PC) ----
LAKE_ROOT=./data/lake
DUCKDB_PATH=./data/lake/gold.duckdb
BTS_YEARS=2024
