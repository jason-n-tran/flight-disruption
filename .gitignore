!.env.*.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Data lake + artifacts (only small bundled samples are committed, under data/sample/)
data/lake/
data/raw/
*.duckdb
*.duckdb.wal
mlruns/
mlartifacts/
*.onnx
*.txt.model
*.lgb
*.pkl

# Re-include the bundled sample artifacts. These negations MUST come AFTER all
# the exclusion patterns above (last-match-wins in gitignore), otherwise the
# sample model.lgb / *.onnx / *.duckdb get excluded and the demo image can't
# load a model on a fresh clone. (This bug shipped once: model.lgb was ignored.)
!data/sample/
!data/sample/**

