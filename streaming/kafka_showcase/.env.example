# Kafka showcase config. Copy to .env (NEVER commit .env) and edit as needed.
# Defaults match docker-compose.kafka.yml and run on a 16GB machine.

# --- Kafka / Redpanda ---
# Host-reachable external listener exposed by docker-compose.kafka.yml.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=flight-positions
CONGESTION_TOPIC=airport-congestion
KAFKA_CLIENT_ID=flight-kafka-showcase-producer

# --- Producer cadence ---
# One US-bbox OpenSky call = 4 credits. 60s is well within the 4000/day
# authenticated budget for a screenshot session. 0 = run forever.
POLL_INTERVAL_SECONDS=60
MAX_POLLS=0

# --- Spark Structured Streaming ---
WINDOW_DURATION=2 minutes
# SLIDE_DURATION blank => tumbling window. Set e.g. "1 minute" for sliding.
SLIDE_DURATION=
WATERMARK_DELAY=1 minute
CELL_SIZE_DEG=0.5
STARTING_OFFSETS=latest
MIN_CONGESTION_COUNT=1
OUTPUT_PATH=./data/congestion_parquet
CHECKPOINT_PATH=./data/checkpoints/congestion
# Re-publish congestion windows to the airport-congestion topic? (true/false)
WRITE_KAFKA=false

# --- OpenSky (reused via flight_ingest; anonymous if blank, 400 credits/day) ---
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# On this dev machine the corporate SSL proxy breaks verification — set false
# for real live runs here. Leave true in normal environments.
INGEST_SSL_VERIFY=true
