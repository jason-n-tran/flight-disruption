# flight_stream (live position path) configuration — copy to .env, never commit.

# ---- NATS JetStream (event bus). Prod: TrueNAS NATS. ----
NATS_URL=nats://localhost:4223
NATS_SUBJECT=flight.positions
NATS_STREAM=FLIGHT_POSITIONS

# ---- Valkey (Redis-protocol live cache). Prod: shared TrueNAS Valkey. ----
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_DB=0

# ---- Viewer-gated polling cadence ----
# Active cadence when a viewer was seen recently. 60s is safe because viewer-
# gating means we are NOT polling 24/7 (4000 credits/day / 4 per US-bbox call
# = ~1000 calls/day budget; gated polling stays well under it).
POLL_INTERVAL_SECONDS=60
# Idle back-off when nobody is watching the map (no OpenSky call is made).
IDLE_INTERVAL_SECONDS=600
# A viewer counts as "recent" if flight:viewer:last_seen is within this window.
# The serving API refreshes that key on each live request.
VIEWER_ACTIVE_WINDOW_SECONDS=300

# ---- Cache TTLs ----
# Short TTL on the live key: if it expires the API knows live went stale.
POSITIONS_TTL_SECONDS=300
# Long TTL on the cached fallback key so the map is never empty.
POSITIONS_CACHED_TTL_SECONDS=86400

# ---- Resilience ----
# Default 429 back-off when Retry-After is absent.
RATE_LIMIT_BACKOFF_SECONDS=60

# ---- OpenSky OAuth2 client-credentials (optional). ----
# Blank => anonymous fetch (~400 credits/day) with a logged warning.
# Set both for the registered-account budget (~4000 credits/day).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ---- SSL escape hatch (inherited by flight_ingest's HTTP client). ----
# Leave true in production. On the corporate-proxy dev machine set false.
INGEST_SSL_VERIFY=true
