# flight_ingest configuration — copy to .env and adjust. Never commit .env.

# Bronze lake root (shared across all components; contract.paths() reads this).
LAKE_ROOT=./data/lake

# Where raw downloads (BTS zips, airports.dat) are cached for resumability.
INGEST_DATA_DIR=./data/raw

# SSL verification for outbound HTTP. Leave true for production.
# On the corporate-proxy dev machine this must be false (the proxy breaks
# certificate verification). Documented escape hatch — see README.
INGEST_SSL_VERIFY=true

# HTTP tuning.
INGEST_HTTP_TIMEOUT=120
INGEST_REQUEST_PAUSE_SEC=0.5
INGEST_MAX_RETRIES=4
INGEST_USER_AGENT=flight-disruption-platform/0.1 (portfolio; ingestion)

# OpenSky OAuth2 client-credentials. Optional: if blank, the snapshot fetcher
# degrades to anonymous (rate-limited to ~400 credits/day) with a warning.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
