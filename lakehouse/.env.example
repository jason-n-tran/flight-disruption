# flight_lakehouse configuration. Copy to .env and adjust. Never commit .env.

# Root of the medallion (bronze/ silver/ gold/ live under it).
LAKE_ROOT=./data/lake

# DuckDB file the dbt project + serving layer read.
DUCKDB_PATH=./data/lake/gold.duckdb

# Output format: parquet (default) or delta. delta needs the `delta` extra.
LAKE_FORMAT=parquet

# Spark tuning for a single 16GB workstation.
SPARK_DRIVER_MEMORY=6g
SPARK_SHUFFLE_PARTITIONS=64
# SPARK_LOCAL_DIR=/tmp/spark
